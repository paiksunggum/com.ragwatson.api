# 이 파일을 복사해 backend/.env 로 저장한 뒤 값을 채우세요.
# cp .env.example .env   (Unix) / copy .env.example .env   (Windows)

# Neon 등 비동기 PostgreSQL URL (선택, 없으면 DB 관련 엔드포인트는 503)
DATABASE_URL=

# Google Gemini API 키 (/chat 등)
GEMINI_API_KEY=

# Gemini 모델 ID (선택, 기본 gemini-2.5-flash)
# GEMINI_MODEL=

# OpenWeatherMap API 키 (네비게이션 날씨 위젯)
OPENWEATHER_API_KEY=
